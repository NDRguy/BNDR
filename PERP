## 1. Batch Processing Module (`batch_processor.py`)

```python
# batch_processor.py - Batch processing for multiple measurements
import pandas as pd
from pathlib import Path
from typing import List, Dict, Optional
import json
from datetime import datetime
from concurrent.futures import ProcessPoolExecutor, as_completed
import logging
from production_pipeline import process_measurement

# Configure logging
logging.basicConfig(
    level=logging.INFO,
    format='%(asctime)s - %(levelname)s - %(message)s',
    handlers=[
        logging.FileHandler('batch_processing.log'),
        logging.StreamHandler()
    ]
)
logger = logging.getLogger(__name__)

class BatchProcessor:
    """Process multiple measurements in parallel with comprehensive reporting."""
    
    def __init__(self, 
                 manifest_path: str,
                 output_base_dir: str = "batch_output",
                 max_workers: int = 4,
                 upload_ipfs: bool = False,
                 register_blockchain: bool = False,
                 contract_address: Optional[str] = None,
                 private_key: Optional[str] = None):
        """
        Initialize batch processor.
        
        Args:
            manifest_path: Path to CSV manifest file
            output_base_dir: Base directory for all outputs
            max_workers: Maximum parallel workers
            upload_ipfs: Enable IPFS upload
            register_blockchain: Enable blockchain registration
            contract_address: Smart contract address
            private_key: Private key for transactions
        """
        self.manifest_path = manifest_path
        self.output_base_dir = Path(output_base_dir)
        self.max_workers = max_workers
        self.upload_ipfs = upload_ipfs
        self.register_blockchain = register_blockchain
        self.contract_address = contract_address
        self.private_key = private_key
        
        self.output_base_dir.mkdir(parents=True, exist_ok=True)
        
    def load_manifest(self) -> pd.DataFrame:
        """
        Load processing manifest from CSV.
        
        Expected columns:
        - sample_id: Unique sample identifier
        - lab_id: Laboratory identifier
        - iv_filepath: Path to I-V curve CSV
        - relaxation_filepath: Path to relaxation CSV (optional)
        - priority: Processing priority (optional, default=1)
        """
        logger.info(f"Loading manifest from {self.manifest_path}")
        df = pd.read_csv(self.manifest_path)
        
        required_cols = ['sample_id', 'lab_id', 'iv_filepath']
        missing = set(required_cols) - set(df.columns)
        if missing:
            raise ValueError(f"Manifest missing required columns: {missing}")
        
        # Add optional columns with defaults
        if 'relaxation_filepath' not in df.columns:
            df['relaxation_filepath'] = None
        if 'priority' not in df.columns:
            df['priority'] = 1
            
        logger.info(f"Loaded {len(df)} measurements from manifest")
        return df
    
    def process_single(self, row: pd.Series) -> Dict:
        """Process a single measurement from manifest row."""
        sample_id = row['sample_id']
        logger.info(f"Processing {sample_id}...")
        
        try:
            output_dir = self.output_base_dir / sample_id
            
            result = process_measurement(
                iv_filepath=row['iv_filepath'],
                relaxation_filepath=row.get('relaxation_filepath'),
                sample_id=sample_id,
                lab_id=row['lab_id'],
                output_dir=str(output_dir),
                upload_ipfs=self.upload_ipfs,
                register_blockchain=self.register_blockchain,
                contract_address=self.contract_address,
                private_key=self.private_key
            )
            
            result['sample_id'] = sample_id
            result['status'] = 'SUCCESS'
            logger.info(f"✓ {sample_id} completed successfully")
            return result
            
        except Exception as e:
            logger.error(f"✗ {sample_id} failed: {e}")
            return {
                'sample_id': sample_id,
                'status': 'FAILED',
                'error': str(e),
                'fingerprint': None,
                'ipfs_cid': None,
                'tx_hash': None
            }
    
    def process_batch(self) -> Dict:
        """Process all measurements in manifest with parallel execution."""
        manifest = self.load_manifest()
        
        # Sort by priority (higher first)
        manifest = manifest.sort_values('priority', ascending=False)
        
        results = []
        start_time = datetime.now()
        
        logger.info(f"Starting batch processing with {self.max_workers} workers")
        
        with ProcessPoolExecutor(max_workers=self.max_workers) as executor:
            # Submit all jobs
            future_to_sample = {
                executor.submit(self.process_single, row): row['sample_id']
                for _, row in manifest.iterrows()
            }
            
            # Collect results as they complete
            for future in as_completed(future_to_sample):
                sample_id = future_to_sample[future]
                try:
                    result = future.result()
                    results.append(result)
                except Exception as e:
                    logger.error(f"Unexpected error processing {sample_id}: {e}")
                    results.append({
                        'sample_id': sample_id,
                        'status': 'FAILED',
                        'error': str(e)
                    })
        
        end_time = datetime.now()
        duration = (end_time - start_time).total_seconds()
        
        # Generate summary report
        summary = self._generate_summary(results, duration)
        
        # Save results
        self._save_results(results, summary)
        
        return summary
    
    def _generate_summary(self, results: List[Dict], duration: float) -> Dict:
        """Generate processing summary statistics."""
        total = len(results)
        successful = sum(1 for r in results if r['status'] == 'SUCCESS')
        failed = total - successful
        
        qc_flags = {}
        for r in results:
            if r['status'] == 'SUCCESS':
                flag = r.get('qc_flag', 'UNKNOWN')
                qc_flags[flag] = qc_flags.get(flag, 0) + 1
        
        ipfs_uploads = sum(1 for r in results if r.get('ipfs_cid'))
        blockchain_txs = sum(1 for r in results if r.get('tx_hash'))
        
        summary = {
            'batch_id': datetime.now().strftime('%Y%m%d_%H%M%S'),
            'timestamp': datetime.now().isoformat(),
            'total_measurements': total,
            'successful': successful,
            'failed': failed,
            'success_rate': successful / total if total > 0 else 0,
            'duration_seconds': duration,
            'avg_time_per_measurement': duration / total if total > 0 else 0,
            'qc_flag_distribution': qc_flags,
            'ipfs_uploads': ipfs_uploads,
            'blockchain_registrations': blockchain_txs
        }
        
        logger.info("=" * 80)
        logger.info("BATCH PROCESSING SUMMARY")
        logger.info("=" * 80)
        logger.info(f"Total: {total} | Success: {successful} | Failed: {failed}")
        logger.info(f"Success Rate: {summary['success_rate']:.1%}")
        logger.info(f"Duration: {duration:.1f}s ({summary['avg_time_per_measurement']:.2f}s/measurement)")
        logger.info(f"QC Flags: {qc_flags}")
        
        return summary
    
    def _save_results(self, results: List[Dict], summary: Dict):
        """Save batch results and summary to files."""
        batch_id = summary['batch_id']
        
        # Save detailed results
        results_path = self.output_base_dir / f'batch_results_{batch_id}.json'
        with open(results_path, 'w') as f:
            json.dump(results, f, indent=2)
        logger.info(f"Saved detailed results to {results_path}")
        
        # Save summary
        summary_path = self.output_base_dir / f'batch_summary_{batch_id}.json'
        with open(summary_path, 'w') as f:
            json.dump(summary, f, indent=2)
        logger.info(f"Saved summary to {summary_path}")
        
        # Save CSV report
        df_results = pd.DataFrame(results)
        csv_path = self.output_base_dir / f'batch_report_{batch_id}.csv'
        df_results.to_csv(csv_path, index=False)
        logger.info(f"Saved CSV report to {csv_path}")
        
        # Save fingerprint registry
        fingerprints = {
            r['sample_id']: r.get('fingerprint')
            for r in results if r.get('fingerprint')
        }
        fp_path = self.output_base_dir / f'fingerprint_registry_{batch_id}.json'
        with open(fp_path, 'w') as f:
            json.dump(fingerprints, f, indent=2)
        logger.info(f"Saved fingerprint registry to {fp_path}")

# ============================================================================
# CLI INTERFACE
# ============================================================================

def main():
    """Command-line interface for batch processing."""
    import argparse
    
    parser = argparse.ArgumentParser(description='Batch process NDR/fractional measurements')
    parser.add_argument('manifest', help='Path to manifest CSV file')
    parser.add_argument('--output-dir', default='batch_output', help='Output directory')
    parser.add_argument('--workers', type=int, default=4, help='Number of parallel workers')
    parser.add_argument('--ipfs', action='store_true', help='Upload to IPFS')
    parser.add_argument('--blockchain', action='store_true', help='Register on blockchain')
    parser.add_argument('--contract', help='Smart contract address')
    parser.add_argument('--private-key', help='Private key for blockchain transactions')
    
    args = parser.parse_args()
    
    processor = BatchProcessor(
        manifest_path=args.manifest,
        output_base_dir=args.output_dir,
        max_workers=args.workers,
        upload_ipfs=args.ipfs,
        register_blockchain=args.blockchain,
        contract_address=args.contract,
        private_key=args.private_key
    )
    
    summary = processor.process_batch()
    
    print("\n" + "=" * 80)
    print("BATCH PROCESSING COMPLETE")
    print("=" * 80)
    print(f"Success Rate: {summary['success_rate']:.1%}")
    print(f"Total Time: {summary['duration_seconds']:.1f}s")

if __name__ == "__main__":
    main()
```


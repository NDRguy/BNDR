## 3. Solidity Deployment Scripts

### `deploy_contract.py`

```python
# deploy_contract.py - Deploy NDR Registry smart contract
from web3 import Web3
from solcx import compile_source, install_solc
import json
from pathlib import Path
from typing import Dict, Tuple

# Install specific Solidity version
install_solc('0.8.20')

def compile_contract(contract_path: str = 'NDRRegistry.sol') -> Tuple[str, str]:
    """Compile Solidity contract and return ABI and bytecode."""
    
    with open(contract_path, 'r') as f:
        contract_source = f.read()
    
    compiled = compile_source(
        contract_source,
        output_values=['abi', 'bin'],
        solc_version='0.8.20'
    )
    
    contract_id, contract_interface = compiled.popitem()
    abi = contract_interface['abi']
    bytecode = contract_interface['bin']
    
    return abi, bytecode

def deploy_contract(
    w3: Web3,
    abi: str,
    bytecode: str,
    deployer_address: str,
    private_key: str,
    gas_limit: int = 3000000
) -> Tuple[str, str]:
    """
    Deploy contract to blockchain.
    
    Returns:
        (contract_address, transaction_hash)
    """
    
    Contract = w3.eth.contract(abi=abi, bytecode=bytecode)
    
    # Build deployment transaction
    txn = Contract.constructor().build_transaction({
        'from': deployer_address,
        'nonce': w3.eth.get_transaction_count(deployer_address),
        'gas': gas_limit,
        'gasPrice': w3.eth.gas_price
    })
    
    # Sign transaction
    signed_txn = w3.eth.account.sign_transaction(txn, private_key)
    
    # Send transaction
    tx_hash = w3.eth.send_raw_transaction(signed_txn.rawTransaction)
    
    print(f"Deployment transaction sent: {tx_hash.hex()}")
    print("Waiting for confirmation...")
    
    # Wait for receipt
    tx_receipt = w3.eth.wait_for_transaction_receipt(tx_hash)
    
    contract_address = tx_receipt['contractAddress']
    
    print(f"✓ Contract deployed at: {contract_address}")
    print(f"  Gas used: {tx_receipt['gasUsed']}")
    print(f"  Block: {tx_receipt['blockNumber']}")
    
    return contract_address, tx_hash.hex()

def save_deployment_info(
    contract_address: str,
    tx_hash: str,
    abi: str,
    network: str,
    output_path: str = 'deployment_info.json'
):
    """Save deployment information for later use."""
    
    deployment_info = {
        'contract_address': contract_address,
        'deployment_tx': tx_hash,
        'network': network,
        'abi': abi,
        'deployed_at': str(Path.ctime(Path(__file__)))
    }
    
    with open(output_path, 'w') as f:
        json.dump(deployment_info, f, indent=2)
    
    print(f"✓ Deployment info saved to {output_path}")

def main():
    """Deploy contract with configuration."""
    import argparse
    
    parser = argparse.ArgumentParser(description='Deploy NDR Registry contract')
    parser.add_argument('--rpc-url', default='http://localhost:8545', help='Ethereum RPC URL')
    parser.add_argument('--private-key', required=True, help='Deployer private key')
    parser.add_argument('--contract', default='NDRRegistry.sol', help='Contract source file')
    parser.add_argument('--network', default='localhost', help='Network name')
    parser.add_argument('--output', default='deployment_info.json', help='Output file')
    
    args = parser.parse_args()
    
    # Connect to network
    print(f"Connecting to {args.rpc_url}...")
    w3 = Web3(Web3.HTTPProvider(args.rpc_url))
    
    if not w3.is_connected():
        raise ConnectionError("Failed to connect to Ethereum node")
    
    print(f"✓ Connected to network (Chain ID: {w3.eth.chain_id})")
    
    # Get deployer address
    account = w3.eth.account.from_key(args.private_key)
    deployer_address = account.address
    balance = w3.eth.get_balance(deployer_address)
    
    print(f"Deployer: {deployer_address}")
    print(f"Balance: {w3.from_wei(balance, 'ether')} ETH")
    
    # Compile contract
    print(f"\nCompiling {args.contract}...")
    abi, bytecode = compile_contract(args.contract)
    print("✓ Contract compiled successfully")
    
    # Deploy
    print("\nDeploying contract...")
    contract_address, tx_hash = deploy_contract(
        w3, abi, bytecode, deployer_address, args.private_key
    )
    
    # Save deployment info
    save_deployment_info(
        contract_address, tx_hash, abi, args.network, args.output
    )
    
    print("\n" + "=" * 80)
    print("DEPLOYMENT COMPLETE")
    print("=" * 80)
    print(f"Contract Address: {contract_address}")
    print(f"Network: {args.network}")
    print(f"Deployment Info: {args.output}")

if __name__ == "__main__":
    main()
```


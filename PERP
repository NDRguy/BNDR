```python
# interact_contract.py - Interact with deployed NDR Registry
from web3 import Web3
import json
from typing import Dict, Optional

class NDRRegistryClient:
    """Client for interacting with NDR Registry smart contract."""
    
    def __init__(self, rpc_url: str, deployment_info_path: str):
        """Initialize client with deployment info."""
        self.w3 = Web3(Web3.HTTPProvider(rpc_url))
        
        if not self.w3.is_connected():
            raise ConnectionError("Failed to connect to Ethereum node")
        
        # Load deployment info
        with open(deployment_info_path, 'r') as f:
            info = json.load(f)
        
        self.contract_address = info['contract_address']
        self.contract = self.w3.eth.contract(
            address=self.contract_address,
            abi=info['abi']
        )
        
        print(f"✓ Connected to contract at {self.contract_address}")
    
    def register_measurement(
        self,
        data_hash: str,
        ipfs_cid: str,
        sample_id: str,
        lab_id: str,
        private_key: str
    ) -> str:
        """Register a measurement on-chain."""
        
        account = self.w3.eth.account.from_key(private_key)
        
        txn = self.contract.functions.registerMeasurement(
            bytes.fromhex(data_hash),
            ipfs_cid,
            sample_id,
            lab_id
        ).build_transaction({
            'from': account.address,
            'nonce': self.w3.eth.get_transaction_count(account.address),
            'gas': 200000,
            'gasPrice': self.w3.eth.gas_price
        })
        
        signed = self.w3.eth.account.sign_transaction(txn, private_key)
        tx_hash = self.w3.eth.send_raw_transaction(signed.rawTransaction)
        
        receipt = self.w3.eth.wait_for_transaction_receipt(tx_hash)
        
        return tx_hash.hex()
    
    def verify_measurement(self, data_hash: str) -> Optional[Dict]:
        """Verify a measurement exists on-chain."""
        
        exists, measurement = self.contract.functions.verifyMeasurement(
            bytes.fromhex(data_hash)
        ).call()
        
        if not exists:
            return None
        
        return {
            'data_hash': data_hash,
            'ipfs_cid': measurement[1],
            'timestamp': measurement[2],
            'researcher': measurement[3],
            'sample_id': measurement[4],
            'lab_id': measurement[5]
        }
    
    def get_researcher_measurements(self, researcher_address: str) -> list:
        """Get all measurements by a researcher."""
        
        hashes = self.contract.functions.getResearcherMeasurements(
            researcher_address
        ).call()
        
        return [h.hex() for h in hashes]

def main():
    """CLI for contract interaction."""
    import argparse
    
    parser = argparse.ArgumentParser(description='Interact with NDR Registry')
    parser.add_argument('--rpc-url', default='http://localhost:8545')
    parser.add_argument('--deployment-info', default='deployment_info.json')
    
    subparsers = parser.add_subparsers(dest='command', required=True)
    
    # Register command
    register_parser = subparsers.add_parser('register')
    register_parser.add_argument('--hash', required=True)
    register_parser.add_argument('--cid', required=True)
    register_parser.add_argument('--sample-id', required=True)
    register_parser.add_argument('--lab-id', required=True)
    register_parser.add_argument('--private-key', required=True)
    
    # Verify command
    verify_parser = subparsers.add_parser('verify')
    verify_parser.add_argument('--hash', required=True)
    
    # List command
    list_parser = subparsers.add_parser('list')
    list_parser.add_argument('--researcher', required=True)
    
    args = parser.parse_args()
    
    client = NDRRegistryClient(args.rpc_url, args.deployment_info)
    
    if args.command == 'register':
        tx_hash = client.register_measurement(
            args.hash, args.cid, args.sample_id, args.lab_id, args.private_key
        )
        print(f"✓ Registered! TX: {tx_hash}")
    
    elif args.command == 'verify':
        result = client.verify_measurement(args.hash)
        if result:
            print("✓ Measurement verified:")
            print(json.dumps(result, indent=2))
        else:
            print("✗ Measurement not found")
    
    elif args.command == 'list':
        hashes = client.get_researcher_measurements(args.researcher)
        print(f"Found {len(hashes)} measurements:")
        for h in hashes:
            print(f"  - {h}")

if __name__ == "__main__":
    main()
```


import sys
import numpy as np
from PyQt6.QtWidgets import (
    QApplication, QMainWindow, QWidget, QVBoxLayout,
    QHBoxLayout, QPushButton, QSlider, QLabel, QCheckBox, QGroupBox
)
from PyQt6.QtCore import Qt, QTimer
from matplotlib.backends.backend_qtagg import FigureCanvasQTAgg as FigureCanvas
from matplotlib.figure import Figure

# ── Local modules ──────────────────────────────────────────────────────────────
from fndr_analysis import compute_ndr_regions, fit_fndr

# ── Optional: comment out if no hardware connected ────────────────────────────
HARDWARE_MODE = False  # Set True when SMU/Lock-In are physically connected
if HARDWARE_MODE:
    from hardware_driver import SMUDriver, LockInDriver, SweepConfig


class NDRVisualizer(QMainWindow):

    def __init__(self):
        super().__init__()
        self.setWindowTitle("Graphene Touchscreen — NDR/FNDR Real-Time Analyzer")
        self.setGeometry(100, 100, 1200, 750)

        self.scan_count = 0

        # ── Hardware init (only in hardware mode) ─────────────────────────────
        if HARDWARE_MODE:
            config = SweepConfig(v_start=0, v_stop=3, v_step=0.01)
            self.smu = SMUDriver("GPIB0::24::INSTR", config)
            self.lockin = LockInDriver("GPIB0::8::INSTR", frequency=1000.0)

        # ── Voltage axis (simulation mode) ────────────────────────────────────
        self.voltage = np.linspace(0, 3, 300)

        # ── Central widget ────────────────────────────────────────────────────
        self.main_widget = QWidget()
        self.setCentralWidget(self.main_widget)
        main_layout = QHBoxLayout(self.main_widget)

        # ── Left control panel ────────────────────────────────────────────────
        control_panel = QVBoxLayout()

        # Start/Stop button
        self.start_btn = QPushButton("▶  Start Live Scan")
        self.start_btn.setCheckable(True)
        self.start_btn.clicked.connect(self.toggle_scan)
        control_panel.addWidget(self.start_btn)

        # Pressure slider (simulation only)
        pressure_group = QGroupBox("Simulation Controls")
        pressure_layout = QVBoxLayout()
        pressure_layout.addWidget(QLabel("Simulated Finger Pressure:"))
        self.pressure_slider = QSlider(Qt.Orientation.Horizontal)
        self.pressure_slider.setMinimum(1)
        self.pressure_slider.setMaximum(100)
        self.pressure_slider.setValue(50)
        self.pressure_label = QLabel("50 %")
        self.pressure_slider.valueChanged.connect(
            lambda v: self.pressure_label.setText(f"{v} %")
        )
        pressure_layout.addWidget(self.pressure_slider)
        pressure_layout.addWidget(self.pressure_label)
        pressure_group.setLayout(pressure_layout)
        control_panel.addWidget(pressure_group)

        # FNDR sweep toggle
        self.fndr_checkbox = QCheckBox("Enable FNDR AC Sweep")
        self.fndr_checkbox.setChecked(True)
        control_panel.addWidget(self.fndr_checkbox)

        # Status label
        self.status_label = QLabel("Status: Idle")
        self.status_label.setWordWrap(True)
        control_panel.addWidget(self.status_label)

        control_panel.addStretch()
        main_layout.addLayout(control_panel, stretch=1)

        # ── Right matplotlib canvas ───────────────────────────────────────────
        self.fig = Figure(figsize=(9, 6))
        self.canvas = FigureCanvas(self.fig)
        main_layout.addWidget(self.canvas, stretch=4)

        self.ax_iv = self.fig.add_subplot(211)
        self.ax_didv = self.fig.add_subplot(212)
        self.fig.tight_layout(pad=3.0)

        # ── Timer (100 ms = 10 FPS, stable on most systems) ──────────────────
        self.timer = QTimer()
        self.timer.timeout.connect(self.update_plots)

    # ── Scan toggle ───────────────────────────────────────────────────────────
    def toggle_scan(self):
        if self.start_btn.isChecked():
            self.start_btn.setText("⏹  Stop Live Scan")
            self.timer.start(100)
        else:
            self.start_btn.setText("▶  Start Live Scan")
            self.timer.stop()
            self.status_label.setText("Status: Idle")

    # ── Main update loop ──────────────────────────────────────────────────────
    def update_plots(self):
        self.scan_count += 1

        # ── Data acquisition ──────────────────────────────────────────────────
        if HARDWARE_MODE:
            voltage, raw_current = self.smu.sweep()
        else:
            voltage = self.voltage
            raw_current = self._simulate_iv()

        # ── Signal processing ─────────────────────────────────────────────────
        filtered_current, didv, ndr_mask = compute_ndr_regions(voltage, raw_current)

        # ── FNDR AC sweep (every 10 cycles) ───────────────────────────────────
        alpha_text = ""
        if self.fndr_checkbox.isChecked() and self.scan_count % 10 == 0:
            if HARDWARE_MODE:
                freqs, G, Cq = self.lockin.frequency_sweep()
            else:
                freqs, G, Cq = self._simulate_fndr()
            alpha, _ = fit_fndr(freqs, G, Cq)
            if alpha is not None:
                tag = "anomalous FNDR ✓" if alpha < 0.9 else "normal"
                alpha_text = f" | FNDR α = {alpha:.3f} ({tag})"

        self.status_label.setText(
            f"Status: Running | Scan #{self.scan_count}"
            f" | NDR pts: {ndr_mask.sum()}{alpha_text}"
        )

        # ── Render ────────────────────────────────────────────────────────────
        self.ax_iv.clear()
        self.ax_didv.clear()

        # I-V plot
        self.ax_iv.plot(voltage, raw_current, alpha=0.25, color='gray', label='Raw ADC Data')
        self.ax_iv.plot(voltage, filtered_current, color='royalblue', lw=2, label='Filtered Signal')
        if ndr_mask.any():
            self.ax_iv.scatter(
                voltage[ndr_mask], filtered_current[ndr_mask],
                color='red', s=10, zorder=5, label='NDR Event'
            )
        self.ax_iv.set_ylabel("Current (mA)")
        self.ax_iv.set_title("Quantum Tunneling I-V Signature — Graphene tBLG")
        self.ax_iv.grid(True, alpha=0.4)
        self.ax_iv.legend(loc='upper left', fontsize=8)

        # dI/dV plot
        self.ax_didv.plot(voltage, didv, color='darkorchid', lw=2, label='Conductance dI/dV')
        self.ax_didv.axhline(0, color='black', linestyle='--', alpha=0.5)
        if ndr_mask.any():
            self.ax_didv.fill_between(
                voltage, didv, 0,
                where=ndr_mask, color='red', alpha=0.3, label='NDR Region'
            )
        self.ax_didv.set_xlabel("Applied Voltage (V)")
        self.ax_didv.set_ylabel("Conductance (mS)")
        self.ax_didv.grid(True, alpha=0.4)
        self.ax_didv.legend(loc='upper left', fontsize=8)

        # BUG FIX #4: re-apply tight_layout after clear()
        self.fig.tight_layout(pad=3.0)
        self.canvas.draw()

    # ── Simulation helpers (no hardware required) ─────────────────────────────
    def _simulate_iv(self) -> np.ndarray:
        """Emulate quantum tunneling I-V curve with pressure-dependent NDR peak."""
        pressure_factor = self.pressure_slider.value() / 50.0
        peak_center = 1.2 - (pressure_factor * 0.05)
        raw = (
            0.2 * self.voltage
            + (1.5 * pressure_factor)
            * self.voltage
            * np.exp(-(self.voltage - peak_center) ** 2 / 0.15)
        )
        noise = np.random.normal(0, 0.03, size=self.voltage.shape)
        return raw + noise

    def _simulate_fndr(self) -> tuple[np.ndarray, np.ndarray, np.ndarray]:
        """Simulate fractional admittance frequency sweep data."""
        freqs = np.logspace(2, 5, 50)
        omega = 2 * np.pi * freqs
        alpha_true = 0.75  # Anomalous exponent
        G = 1.0 + 0.5 * (omega ** alpha_true) * np.cos(np.pi * alpha_true / 2)
        Cq = 0.5 * (omega ** alpha_true) * np.sin(np.pi * alpha_true / 2)
        G += np.random.normal(0, 0.05, size=freqs.shape)
        Cq += np.random.normal(0, 0.05, size=freqs.shape)
        return freqs, G, Cq

    # ── Cleanup ───────────────────────────────────────────────────────────────
    def closeEvent(self, event):
        self.timer.stop()
        if HARDWARE_MODE:
            self.smu.close()
            self.lockin.close()
        event.accept()


# ── Entry point ───────────────────────────────────────────────────────────────
if __name__ == "__main__":
    app = QApplication(sys.argv)
    window = NDRVisualizer()
    window.show()
    sys.exit(app.exec())

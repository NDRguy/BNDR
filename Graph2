### `fndr_analysis.py`

```python
import numpy as np
from scipy.optimize import curve_fit
from scipy.signal import savgol_filter


def fractional_admittance_model(omega, G0, Cq0, alpha):
    """
    Y(ω) = G0 + Cq0 * (jω)^α
    Non-integer α ∈ (0,1) confirms anomalous FNDR behavior.
    """
    j_omega_alpha = (omega ** alpha) * np.exp(1j * np.pi * alpha / 2)
    Y = G0 + Cq0 * j_omega_alpha
    return np.abs(Y)


def fit_fndr(frequencies: np.ndarray, G_mS: np.ndarray, Cq_pF: np.ndarray):
    """Fit frequency dispersion to fractional-order model. Returns (alpha, params)."""
    omega = 2 * np.pi * frequencies
    Y_magnitude = np.sqrt(G_mS**2 + Cq_pF**2)
    try:
        params, _ = curve_fit(
            fractional_admittance_model,
            omega, Y_magnitude,
            p0=[G_mS.mean(), Cq_pF.mean(), 0.8],
            bounds=([0, 0, 0.01], [np.inf, np.inf, 1.0])
        )
        G0, Cq0, alpha = params
        return alpha, params
    except RuntimeError:
        return None, None


def compute_ndr_regions(voltage: np.ndarray, current: np.ndarray):
    """Filter → dI/dV → NDR mask. Returns (filtered_current, didv, ndr_mask)."""
    filtered = savgol_filter(current, window_length=15, polyorder=3)
    didv = np.gradient(filtered, voltage, edge_order=2)
    ndr_mask = didv < 0
    return filtered, didv, ndr_mask

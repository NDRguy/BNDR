import pyvisa
import numpy as np
import time
from dataclasses import dataclass


@dataclass
class SweepConfig:
    v_start: float = 0.0
    v_stop: float = 3.0
    v_step: float = 0.01
    compliance_current: float = 0.1   # Amps (safety limit)
    series_resistor: float = 1000.0   # Ohms (Rs > |R_NDR| stability criterion)
    nplc: float = 1.0                 # Integration time (power line cycles)


class SMUDriver:
    """Keithley 2400/2450 Source Measure Unit driver via VISA."""

    def __init__(self, resource_address: str, config: SweepConfig):
        self.rm = pyvisa.ResourceManager()
        self.smu = self.rm.open_resource(resource_address)
        self.smu.timeout = 10000
        self.config = config
        self._initialize()

    def _initialize(self):
        self.smu.write("*RST")
        time.sleep(0.5)
        self.smu.write(":SOUR:FUNC VOLT")
        self.smu.write(":SENS:FUNC 'CURR'")
        self.smu.write(f":SENS:CURR:PROT {self.config.compliance_current}")
        self.smu.write(f":SENS:CURR:NPLC {self.config.nplc}")
        self.smu.write(":FORM:ELEM VOLT,CURR")
        self.smu.write(":OUTP ON")

    def sweep(self) -> tuple[np.ndarray, np.ndarray]:
        voltages = np.arange(
            self.config.v_start,
            self.config.v_stop + self.config.v_step,
            self.config.v_step
        )
        currents = np.zeros_like(voltages)
        for i, v in enumerate(voltages):
            self.smu.write(f":SOUR:VOLT {v:.4f}")
            response = self.smu.query(":READ?")
            _, current = map(float, response.strip().split(","))
            currents[i] = current
        return voltages, currents

    def close(self):
        self.smu.write(":OUTP OFF")
        self.smu.close()
        self.rm.close()


class LockInDriver:
    """Stanford Research SR830 Lock-In Amplifier driver via VISA."""

    def __init__(self, resource_address: str, frequency: float = 1000.0, amplitude: float = 0.01):
        self.rm = pyvisa.ResourceManager()
        self.lockin = self.rm.open_resource(resource_address)
        self.lockin.timeout = 5000
        self.frequency = frequency
        self.amplitude = amplitude
        self._initialize()

    def _initialize(self):
        self.lockin.write("*RST")
        time.sleep(0.5)
        self.lockin.write(f"FREQ {self.frequency}")
        self.lockin.write(f"SLVL {self.amplitude}")
        self.lockin.write("SENS 8")
        self.lockin.write("OFLT 8")
        self.lockin.write("ISRC 0")

    def measure_admittance(self) -> tuple[float, float]:
        response = self.lockin.query("SNAP?1,2")
        x, y = map(float, response.strip().split(","))
        omega = 2 * np.pi * self.frequency
        G = x / self.amplitude
        Cq = y / (omega * self.amplitude)
        return G * 1e3, Cq * 1e12  # mS, pF

    def frequency_sweep(
        self, f_start: float = 100, f_stop: float = 1e5, n_points: int = 50
    ) -> tuple[np.ndarray, np.ndarray, np.ndarray]:
        frequencies = np.logspace(np.log10(f_start), np.log10(f_stop), n_points)
        G_arr = np.zeros(n_points)
        Cq_arr = np.zeros(n_points)
        for i, f in enumerate(frequencies):
            self.lockin.write(f"FREQ {f:.2f}")
            time.sleep(0.3)
            G_arr[i], Cq_arr[i] = self.measure_admittance()
        return frequencies, G_arr, Cq_arr

    def close(self):
        self.lockin.close()
        self.rm.close()

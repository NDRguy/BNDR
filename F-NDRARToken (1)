        # Skin resistance (typical range: 1kΩ to 1MΩ)
        # Inversely related to moisture/conductivity
        skin_resistance = 100000.0 / (capacitance / self.baseline_capacitance)
        
        # Total impedance: Z = √(R² + Xc²)
        impedance = np.sqrt(skin_resistance**2 + capacitive_reactance**2)
        
        return impedance
    

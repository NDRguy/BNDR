        current_density = (
            tunneling_probability * 
            field_strength * 
            coupling_factor * 
            1e-6  # Scaling factor
        )
        
        # Total current (convert to nA)
        contact_area_m2 = contact_area * 1e-6  # mm² to m²
        tunneling_current = current_density * contact_area_m2 * 1e9  # nA
        
        return tunneling_current
    

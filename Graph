## Diseño de la GUI con PyQt6 y Matplotlib
Este script crea una ventana de instrumentación profesional en tiempo real. Incluye un botón para iniciar el escaneo de la pantalla táctil de grafeno, controles deslizantes para simular el cambio de presión del dedo (que altera la respuesta cuántica del sensor) y gráficos dinámicos integrados.

import sysimport numpy as npfrom PyQt6.QtWidgets import QApplication, QMainWindow, QWidget, QVBoxLayout, QHBoxLayout, QPushButton, QSlider, QLabelfrom PyQt6.QtCore import Qt, QTimerfrom matplotlib.backends.backend_qtagg import FigureCanvasQTAgg as FigureCanvasfrom matplotlib.figure import Figurefrom scipy.signal import savitzky_golay
class NDRVisualizer(QMainWindow):
    def __init__(self):
        super().__init__()
        self.setWindowTitle("Graphene Touchscreen - NDR/FNDR Real-Time Analyzer")
        self.setGeometry(100, 100, 1000, 700)

        # Main Layout Setup
        self.main_widget = QWidget()
        self.setCentralWidget(self.main_widget)
        main_layout = QHBoxLayout(self.main_widget)

        # Left Control Panel
        control_panel = QVBoxLayout()
        self.start_btn = QPushButton("Start Live Scan")
        self.start_btn.setCheckable(True)
        self.start_btn.clicked.connect(self.toggle_scan)
        control_panel.addWidget(self.start_btn)

        # Finger Pressure Simulation Slider
        control_panel.addWidget(QLabel("Simulated Finger Pressure:"))
        self.pressure_slider = QSlider(Qt.Orientation.Horizontal)
        self.pressure_slider.setMinimum(1)
        self.pressure_slider.setMaximum(100)
        self.pressure_slider.setValue(50)
        control_panel.addWidget(self.pressure_slider)
        
        control_panel.addStretch()
        main_layout.addLayout(control_panel, stretch=1)

        # Right Graphics Panel (Matplotlib Canvas)
        self.fig = Figure(figsize=(8, 6))
        self.canvas = FigureCanvas(self.fig)
        main_layout.addWidget(self.canvas, stretch=4)

        # Subplots configuration
        self.ax_iv = self.fig.add_subplot(211)
        self.ax_didv = self.fig.add_subplot(212)
        self.fig.tight_layout()

        # Timer for data stream emulation (50ms interval)
        self.timer = QTimer()
        self.timer.timeout.connect(self.update_plots)
        
        # Hardware Sweep Data Definition
        self.voltage = np.linspace(0, 3, 300)

    def toggle_scan(self):
        if self.start_btn.isChecked():
            self.start_btn.setText("Stop Live Scan")
            self.timer.start(50)
        else:
            self.start_btn.setText("Start Live Scan")
            self.timer.stop()

    def update_plots(self):
        # 1. Acquire current finger pressure scale factor
        pressure_factor = self.pressure_slider.value() / 50.0

        # 2. Emulate quantum tunneling I-V curve governed by pressure
        # Peak location shifts slightly based on local graphene lattice strain
        peak_center = 1.2 - (pressure_factor * 0.05)
        raw_current = 0.2 * self.voltage + (1.5 * pressure_factor) * self.voltage * np.exp(-(self.voltage - peak_center)**2 / 0.15)
        noise = np.random.normal(0, 0.03, size=self.voltage.shape)
        measured_current = raw_current + noise

        # 3. Apply Savitzky-Golay filter to clean Graphene EMI/thermal noise
        filtered_current = savitzky_golay(measured_current, window_length=15, polyorder=3)

        # 4. Calculate Differential Conductance (dI/dV)
        didv = np.gradient(filtered_current, self.voltage)

        # 5. Locate active NDR regions (where dI/dV < 0)
        ndr_indices = np.where(didv < 0)[0]

        # 6. Render Data to GUI Graphics View
        self.ax_iv.clear()
        self.ax_didv.clear()

        # Plot I-V
        self.ax_iv.plot(self.voltage, measured_current, alpha=0.2, color='gray', label='Raw ADC Data')
        self.ax_iv.plot(self.voltage, filtered_current, color='blue', lw=2, label='Filtered Graphene Signal')
        if len(ndr_indices) > 0:
            self.ax_iv.scatter(self.voltage[ndr_indices], filtered_current[ndr_indices], color='red', s=10, zorder=5, label='NDR Event')
        self.ax_iv.set_ylabel("Current (mA)")
        self.ax_iv.set_title("Quantum Tunneling I-V Signature")
        self.ax_iv.grid(True)
        self.ax_iv.legend(loc='upper left')

        # Plot dI/dV (Conductance)
        self.ax_didv.plot(self.voltage, didv, color='purple', lw=2, label='Conductance (dI/dV)')
        self.ax_didv.axhline(0, color='black', linestyle='--', alpha=0.5)
        if len(ndr_indices) > 0:
            self.ax_didv.fill_between(self.voltage, didv, 0, where=(didv < 0), color='red', alpha=0.3, label='NDR Region')
        self.ax_didv.set_xlabel("Applied Voltage (V)")
        self.ax_didv.set_ylabel("Conductance (mS)")
        self.ax_didv.grid(True)
        self.ax_didv.legend(loc='upper left')

        self.canvas.draw()
if __name__ == "__main__":
    app = QApplication(sys.argv)
    window = NDRVisualizer()
    window.show()
    sys.exit(app.exec())


## 2. Integration with Quantum Tunneling Module

```python
# hardware/fndr_hardware_quantum_layer.py

import asyncio
import numpy as np
from typing import Optional, List, Dict
from fndr_quantum_tunneling import (
    GrapheneQuantumTunnelingLayer,
    FNDRTunnelingMeasurement,
    TunnelingElectronProperties
)
from hardware.fndr_hardware_interface import (
    FNDRHardwareInterface,
    HardwareConnectionType,
    RawSensorData
)


class HardwareGrapheneQuantumLayer(GrapheneQuantumTunnelingLayer):
    """
    Graphene quantum tunneling layer with real hardware integration.
    Combines theoretical calculations with actual sensor measurements.
    """
    
    def __init__(
        self,
        connection_type: HardwareConnectionType = HardwareConnectionType.USB_SERIAL,
        device_id: Optional[str] = None,
        use_hardware: bool = True,
        **kwargs
    ):
        super().__init__(**kwargs)
        
        # Hardware interface
        self.hardware = FNDRHardwareInterface(
            connection_type=connection_type,
            device_id=device_id
        )
        
        self.use_hardware = use_hardware
        self.hardware_connected = False
        
        # Measurement mode
        self.measurement_mode = "hybrid"  # "hardware", "simulation", "hybrid"
        
        # Hardware data correlation
        self.hardware_measurements: List[Dict] = []
        self.correlation_data: List[Dict] = []
        
    async def initialize_hardware(self) -> bool:
        """Initialize hardware connection"""
        if not self.use_hardware:
            logger.info("Hardware disabled, using simulation only")
            return False
        
        try:
            self.hardware_connected = await self.hardware.connect()
            
            if self.hardware_connected:
                logger.info(f"Hardware initialized: {self.hardware.capabilities.serial_number}")
                logger.info(f"Firmware: {self.hardware.capabilities.firmware_version}")
                logger.info(f"Channels: {self.hardware.capabilities.num_channels}")
                
                # Set up data callback
                self.hardware.data_callback = self._on_hardware_data
                
            return self.hardware_connected
            
        except Exception as e:
            logger.error(f"Hardware initialization failed: {e}")
            return False
    
    async def shutdown_hardware(self):
        """Shutdown hardware connection"""
        if self.hardware_connected:
            await self.hardware.disconnect()
            self.hardware_connected = False
    
    def _on_hardware_data(self, raw_data: RawSensorData):
        """Callback for hardware data"""
        try:
            # Convert to physical units
            physical_data = self.hardware.convert_raw_to_physical(raw_data)
            
            # Store hardware measurement
            self.hardware_measurements.append(physical_data)
            
            # Limit storage
            if len(self.hardware_measurements) > 10000:
                self.hardware_measurements.pop(0)
            
        except Exception as e:
            logger.error(f"Error processing hardware data: {e}")
    
    async def measure_fndr_tunneling_hardware(
        self,
        bias_voltage: float,
        temperature: float = 300.0,
        channel: int = 0
    ) -> FNDRTunnelingMeasurement:
        """
        Perform FNDR measurement using real hardware.
        Combines hardware data with theoretical calculations.
        """
        
        if not self.hardware_connected:
            logger.warning("Hardware not connected, falling back to simulation")
            return self.measure_fndr_tunneling(bias_voltage, temperature)
        
        try:
            # Set bias voltage on hardware
            await self.hardware.set_bias_voltage(bias_voltage)
            
            # Wait for settling
            await asyncio.sleep(0.1)
            
            # Read measurement from hardware
            raw_data = await self.hardware.read_measurement(channel)
            
            if raw_data is None:
                logger.error("Failed to read hardware measurement")
                return self.measure_fndr_tunneling(bias_voltage, temperature)
            
            # Convert to physical units
            physical_data = self.hardware.convert_raw_to_physical(raw_data)
            
            # Get theoretical predictions
            theoretical_measurement = self.measure_fndr_tunneling(bias_voltage, temperature)
            
            # Create hybrid measurement combining hardware and theory
            hybrid_measurement = FNDRTunnelingMeasurement(
                timestamp=physical_data["timestamp"],
                bias_voltage=physical_data["voltage"],
                tunneling_current=physical_data["current"],  # Use hardware current
                differential_resistance=theoretical_measurement.differential_resistance,
                fractional_order=theoretical_measurement.fractional_order,
                ndr_coefficient=theoretical_measurement.ndr_coefficient,
                electron_flux=physical_data["current"] / 1.602e-10,  # Convert nA to electrons/s
                barrier_transparency=theoretical_measurement.barrier_transparency,
                quantum_coherence=theoretical_measurement.quantum_coherence,
                memory_kernel_decay=theoretical_measurement.memory_kernel_decay
            )
            
            # Store correlation data
            self.correlation_data.append({
                "timestamp": physical_data["timestamp"],
                "voltage": bias_voltage,
                "hardware_current": physical_data["current"],
                "theoretical_current": theoretical_measurement.tunneling_current,
                "temperature": physical_data.get("temperature", temperature),
                "pressure": physical_data.get("pressure", None)
            })
            
            # Store measurement
            self.tunneling_measurements.append(hybrid_measurement)
            
            return hybrid_measurement
            
        except Exception as e:
            logger.error(f"Hardware measurement failed: {e}")
            return self.measure_fndr_tunneling(bias_voltage, temperature)
    
    async def perform_iv_sweep(
        self,
        voltage_start: float,
        voltage_end: float,
        num_points: int = 50,
        channel: int = 0
    ) -> Dict[str, List[float]]:
        """Perform I-V characteristic sweep"""
        
        voltages = np.linspace(voltage_start, voltage_end, num_points)
        currents_hw = []
        currents_theory = []
        resistances = []
        ndr_coefficients = []
        
        for voltage in voltages:
            measurement = await self.measure_fndr_tunneling_hardware(voltage, channel=channel)
            
            currents_hw.append(measurement.tunneling_current)
            
            # Get theoretical current
            theoretical = self.measure_fndr_tunneling(voltage)
            currents_theory.append(theoretical.tunneling_current)
            
            resistances.append(measurement.differential_resistance)
            ndr_coefficients.append(measurement.ndr_coefficient)
            
            # Small delay between measurements
            await asyncio.sleep(0.05)
        
        return {
            "voltages": voltages.tolist(),
            "currents_hardware": currents_hw,
            "currents_theoretical": currents_theory,
            "differential_resistance": resistances,
            "ndr_coefficients": ndr_coefficients
        }
    
    async def start_realtime_monitoring(
        self,
        sampling_rate: int = 100,
        channels: List[int] = [0]
    ):
        """Start real-time hardware monitoring"""
        if not self.hardware_connected:
            logger.error("Hardware not connected")
            return
        
        await self.hardware.start_continuous_measurement(
            sampling_rate=sampling_rate,
            channels=channels
        )
    
    async def stop_realtime_monitoring(self):
        """Stop real-time hardware monitoring"""
        if self.hardware_connected:
            await self.hardware.stop_continuous_measurement()
    
    def get_correlation_statistics(self) -> Dict[str, float]:
        """Calculate correlation between hardware and theoretical measurements"""
        if len(self.correlation_data) < 2:
            return {}
        
        hw_currents = [d["hardware_current"] for d in self.correlation_data]
        th_currents = [d["theoretical_current"] for d in self.correlation_data]
        
        # Calculate correlation coefficient
        correlation = np.corrcoef(hw_currents, th_currents)[0, 1]
        
        # Calculate mean absolute error
        mae = np.mean(np.abs(np.array(hw_currents) - np.array(th_currents)))
        
        # Calculate relative error
        relative_error = mae / np.mean(hw_currents) * 100
        
        return {
            "correlation_coefficient": correlation,
            "mean_absolute_error_nA": mae,
            "relative_error_percent": relative_error,
            "num_measurements": len(self.correlation_data),
            "hardware_mean_current_nA": np.mean(hw_currents),
            "theoretical_mean_current_nA": np.mean(th_currents)
        }
    
    def get_hardware_statistics(self) -> Dict:
        """Get comprehensive hardware statistics"""
        stats = self.get_fndr_statistics()
        
        if self.hardware_connected:
            stats["hardware_connected"] = True
            stats["hardware_serial"] = self.hardware.capabilities.serial_number
            stats["hardware_firmware"] = self.hardware.capabilities.firmware_version
            stats["hardware_channels"] = self.hardware.capabilities.num_channels
            stats["hardware_buffer_size"] = len(self.hardware.data_buffer)
            
            # Add correlation statistics
            stats.update(self.get_correlation_statistics())
        else:
            stats["hardware_connected"] = False
        
        return stats

# Complete Hardware Control Integration for FNDR Quantum Tunneling Module

## 1. Hardware Communication Layer

```python
# hardware/fndr_hardware_interface.py

import asyncio
import struct
from typing import Optional, Callable, Dict, List
from dataclasses import dataclass
from enum import Enum
import logging
import time

try:
    import serial
    import serial.tools.list_ports
except ImportError:
    print("Install pyserial: pip install pyserial")

try:
    from bleak import BleakClient, BleakScanner
except ImportError:
    print("Install bleak for Bluetooth: pip install bleak")

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)


class HardwareConnectionType(Enum):
    """Hardware connection protocols"""
    USB_SERIAL = "usb_serial"
    BLUETOOTH_LE = "bluetooth_le"
    SPI = "spi"
    I2C = "i2c"
    NETWORK = "network"


class SensorStatus(Enum):
    """Sensor operational status"""
    DISCONNECTED = 0
    CONNECTING = 1
    CONNECTED = 2
    CALIBRATING = 3
    READY = 4
    MEASURING = 5
    ERROR = 6


@dataclass
class HardwareCapabilities:
    """Hardware sensor capabilities"""
    max_voltage: float  # V
    min_voltage: float  # V
    voltage_resolution: float  # V
    max_current: float  # A
    current_resolution: float  # A
    sampling_rate: int  # Hz
    num_channels: int
    supports_temperature: bool
    supports_pressure: bool
    firmware_version: str
    serial_number: str


@dataclass
class RawSensorData:
    """Raw data from hardware sensor"""
    timestamp: float
    channel: int
    voltage_raw: int  # ADC counts
    current_raw: int  # ADC counts
    temperature_raw: Optional[int] = None
    pressure_raw: Optional[int] = None
    status_flags: int = 0


class FNDRHardwareInterface:
    """
    Base hardware interface for FNDR quantum tunneling sensors.
    Supports multiple connection types and real-time data acquisition.
    """
    
    def __init__(
        self,
        connection_type: HardwareConnectionType = HardwareConnectionType.USB_SERIAL,
        device_id: Optional[str] = None,
        baud_rate: int = 115200,
        timeout: float = 1.0
    ):
        self.connection_type = connection_type
        self.device_id = device_id
        self.baud_rate = baud_rate
        self.timeout = timeout
        
        self.status = SensorStatus.DISCONNECTED
        self.capabilities: Optional[HardwareCapabilities] = None
        self.connection = None
        
        # Calibration data
        self.voltage_calibration = {"offset": 0.0, "scale": 1.0}
        self.current_calibration = {"offset": 0.0, "scale": 1.0}
        
        # Data buffers
        self.data_buffer: List[RawSensorData] = []
        self.max_buffer_size = 10000
        
        # Callbacks
        self.data_callback: Optional[Callable] = None
        self.error_callback: Optional[Callable] = None
        
    async def connect(self) -> bool:
        """Connect to hardware sensor"""
        try:
            self.status = SensorStatus.CONNECTING
            
            if self.connection_type == HardwareConnectionType.USB_SERIAL:
                success = await self._connect_usb_serial()
            elif self.connection_type == HardwareConnectionType.BLUETOOTH_LE:
                success = await self._connect_bluetooth()
            else:
                raise NotImplementedError(f"Connection type {self.connection_type} not implemented")
            
            if success:
                # Read capabilities
                self.capabilities = await self._read_capabilities()
                
                # Perform calibration
                await self.calibrate()
                
                self.status = SensorStatus.READY
                logger.info(f"Connected to FNDR sensor: {self.capabilities.serial_number}")
                return True
            
            return False
            
        except Exception as e:
            self.status = SensorStatus.ERROR
            logger.error(f"Connection failed: {e}")
            if self.error_callback:
                self.error_callback(e)
            return False
    
    async def _connect_usb_serial(self) -> bool:
        """Connect via USB serial"""
        try:
            if self.device_id is None:
                # Auto-detect FNDR device
                ports = serial.tools.list_ports.comports()
                for port in ports:
                    if "FNDR" in port.description or "Quantum" in port.description:
                        self.device_id = port.device
                        break
                
                if self.device_id is None:
                    logger.error("No FNDR device found")
                    return False
            
            self.connection = serial.Serial(
                port=self.device_id,
                baudrate=self.baud_rate,
                timeout=self.timeout,
                bytesize=serial.EIGHTBITS,
                parity=serial.PARITY_NONE,
                stopbits=serial.STOPBITS_ONE
            )
            
            # Wait for device ready
            await asyncio.sleep(0.5)
            
            # Send handshake
            self.connection.write(b'FNDR_CONNECT\n')
            response = self.connection.readline().decode().strip()
            
            return response == "FNDR_READY"
            
        except Exception as e:
            logger.error(f"USB serial connection failed: {e}")
            return False
    
    async def _connect_bluetooth(self) -> bool:
        """Connect via Bluetooth LE"""
        try:
            if self.device_id is None:
                # Scan for FNDR devices
                devices = await BleakScanner.discover(timeout=5.0)
                for device in devices:
                    if "FNDR" in device.name:
                        self.device_id = device.address
                        break
                
                if self.device_id is None:
                    logger.error("No FNDR Bluetooth device found")
                    return False
            
            self.connection = BleakClient(self.device_id)
            await self.connection.connect()
            
            # Subscribe to notifications
            await self.connection.start_notify(
                "00002a58-0000-1000-8000-00805f9b34fb",  # Custom FNDR characteristic
                self._bluetooth_notification_handler
            )
            
            return self.connection.is_connected
            
        except Exception as e:
            logger.error(f"Bluetooth connection failed: {e}")
            return False
    
    async def disconnect(self):
        """Disconnect from hardware"""
        try:
            if self.connection_type == HardwareConnectionType.USB_SERIAL:
                if self.connection and self.connection.is_open:
                    self.connection.write(b'FNDR_DISCONNECT\n')
                    self.connection.close()
            
            elif self.connection_type == HardwareConnectionType.BLUETOOTH_LE:
                if self.connection and self.connection.is_connected:
                    await self.connection.disconnect()
            
            self.status = SensorStatus.DISCONNECTED
            logger.info("Disconnected from FNDR sensor")
            
        except Exception as e:
            logger.error(f"Disconnect error: {e}")
    
    async def _read_capabilities(self) -> HardwareCapabilities:
        """Read hardware capabilities from device"""
        try:
            if self.connection_type == HardwareConnectionType.USB_SERIAL:
                self.connection.write(b'GET_CAPABILITIES\n')
                response = self.connection.readline().decode().strip()
                
                # Parse response (format: "CAP:max_v,min_v,v_res,max_i,i_res,rate,ch,temp,press,fw,sn")
                parts = response.split(':')[1].split(',')
                
                return HardwareCapabilities(
                    max_voltage=float(parts[0]),
                    min_voltage=float(parts[1]),
                    voltage_resolution=float(parts[2]),
                    max_current=float(parts[3]),
                    current_resolution=float(parts[4]),
                    sampling_rate=int(parts[5]),
                    num_channels=int(parts[6]),
                    supports_temperature=parts[7] == '1',
                    supports_pressure=parts[8] == '1',
                    firmware_version=parts[9],
                    serial_number=parts[10]
                )
            
            # Default capabilities if read fails
            return HardwareCapabilities(
                max_voltage=2.0,
                min_voltage=-2.0,
                voltage_resolution=0.001,
                max_current=1e-6,
                current_resolution=1e-12,
                sampling_rate=1000,
                num_channels=4,
                supports_temperature=True,
                supports_pressure=True,
                firmware_version="1.0.0",
                serial_number="UNKNOWN"
            )
            
        except Exception as e:
            logger.error(f"Failed to read capabilities: {e}")
            raise
    
    async def calibrate(self) -> bool:
        """Perform sensor calibration"""
        try:
            self.status = SensorStatus.CALIBRATING
            logger.info("Starting calibration...")
            
            if self.connection_type == HardwareConnectionType.USB_SERIAL:
                # Zero calibration
                self.connection.write(b'CALIBRATE_ZERO\n')
                await asyncio.sleep(2.0)
                
                # Read calibration data
                self.connection.write(b'GET_CALIBRATION\n')
                response = self.connection.readline().decode().strip()
                
                # Parse: "CAL:v_offset,v_scale,i_offset,i_scale"
                parts = response.split(':')[1].split(',')
                
                self.voltage_calibration = {
                    "offset": float(parts[0]),
                    "scale": float(parts[1])
                }
                self.current_calibration = {
                    "offset": float(parts[2]),
                    "scale": float(parts[3])
                }
            
            logger.info("Calibration complete")
            return True
            
        except Exception as e:
            logger.error(f"Calibration failed: {e}")
            return False
    
    async def set_bias_voltage(self, voltage: float) -> bool:
        """Set bias voltage on sensor"""
        try:
            if not self.capabilities:
                raise RuntimeError("Device not connected")
            
            # Clamp to hardware limits
            voltage = max(self.capabilities.min_voltage, 
                         min(self.capabilities.max_voltage, voltage))
            
            if self.connection_type == HardwareConnectionType.USB_SERIAL:
                command = f'SET_VOLTAGE:{voltage:.6f}\n'.encode()
                self.connection.write(command)
                response = self.connection.readline().decode().strip()
                return response == "OK"
            
            return False
            
        except Exception as e:
            logger.error(f"Failed to set voltage: {e}")
            return False
    
    async def read_measurement(self, channel: int = 0) -> Optional[RawSensorData]:
        """Read single measurement from sensor"""
        try:
            if self.connection_type == HardwareConnectionType.USB_SERIAL:
                command = f'READ_CHANNEL:{channel}\n'.encode()
                self.connection.write(command)
                response = self.connection.readline().decode().strip()
                
                # Parse: "DATA:timestamp,ch,v_raw,i_raw,t_raw,p_raw,flags"
                parts = response.split(':')[1].split(',')
                
                data = RawSensorData(
                    timestamp=float(parts[0]),
                    channel=int(parts[1]),
                    voltage_raw=int(parts[2]),
                    current_raw=int(parts[3]),
                    temperature_raw=int(parts[4]) if parts[4] != 'N' else None,
                    pressure_raw=int(parts[5]) if parts[5] != 'N' else None,
                    status_flags=int(parts[6])
                )
                
                # Add to buffer
                self.data_buffer.append(data)
                if len(self.data_buffer) > self.max_buffer_size:
                    self.data_buffer.pop(0)
                
                return data
            
            return None
            
        except Exception as e:
            logger.error(f"Failed to read measurement: {e}")
            return None
    
    async def start_continuous_measurement(
        self,
        sampling_rate: int = 100,
        channels: List[int] = [0]
    ):
        """Start continuous data acquisition"""
        try:
            self.status = SensorStatus.MEASURING
            
            if self.connection_type == HardwareConnectionType.USB_SERIAL:
                command = f'START_CONTINUOUS:{sampling_rate},{",".join(map(str, channels))}\n'.encode()
                self.connection.write(command)
                
                # Start reading loop
                asyncio.create_task(self._continuous_read_loop())
            
            logger.info(f"Started continuous measurement at {sampling_rate} Hz")
            
        except Exception as e:
            logger.error(f"Failed to start continuous measurement: {e}")
    
    async def stop_continuous_measurement(self):
        """Stop continuous data acquisition"""
        try:
            if self.connection_type == HardwareConnectionType.USB_SERIAL:
                self.connection.write(b'STOP_CONTINUOUS\n')
            
            self.status = SensorStatus.READY
            logger.info("Stopped continuous measurement")
            
        except Exception as e:
            logger.error(f"Failed to stop continuous measurement: {e}")
    
    async def _continuous_read_loop(self):
        """Background loop for continuous data reading"""
        while self.status == SensorStatus.MEASURING:
            try:
                if self.connection.in_waiting > 0:
                    line = self.connection.readline().decode().strip()
                    
                    if line.startswith("DATA:"):
                        parts = line.split(':')[1].split(',')
                        
                        data = RawSensorData(
                            timestamp=float(parts[0]),
                            channel=int(parts[1]),
                            voltage_raw=int(parts[2]),
                            current_raw=int(parts[3]),
                            temperature_raw=int(parts[4]) if parts[4] != 'N' else None,
                            pressure_raw=int(parts[5]) if parts[5] != 'N' else None,
                            status_flags=int(parts[6])
                        )
                        
                        # Add to buffer
                        self.data_buffer.append(data)
                        if len(self.data_buffer) > self.max_buffer_size:
                            self.data_buffer.pop(0)
                        
                        # Trigger callback
                        if self.data_callback:
                            self.data_callback(data)
                
                await asyncio.sleep(0.001)  # Small delay to prevent CPU spinning
                
            except Exception as e:
                logger.error(f"Error in continuous read loop: {e}")
                if self.error_callback:
                    self.error_callback(e)
    
    def _bluetooth_notification_handler(self, sender, data: bytearray):
        """Handle Bluetooth LE notifications"""
        try:
            # Parse binary data (custom protocol)
            # Format: timestamp(4), channel(1), voltage(2), current(2), temp(2), pressure(2), flags(1)
            if len(data) >= 14:
                timestamp, channel, v_raw, i_raw, t_raw, p_raw, flags = struct.unpack(
                    '<fBHHHHB', data[:14]
                )
                
                sensor_data = RawSensorData(
                    timestamp=timestamp,
                    channel=channel,
                    voltage_raw=v_raw,
                    current_raw=i_raw,
                    temperature_raw=t_raw if t_raw != 0xFFFF else None,
                    pressure_raw=p_raw if p_raw != 0xFFFF else None,
                    status_flags=flags
                )
                
                self.data_buffer.append(sensor_data)
                if len(self.data_buffer) > self.max_buffer_size:
                    self.data_buffer.pop(0)
                
                if self.data_callback:
                    self.data_callback(sensor_data)
                    
        except Exception as e:
            logger.error(f"Bluetooth notification error: {e}")
    
    def convert_raw_to_physical(self, raw_data: RawSensorData) -> Dict[str, float]:
        """Convert raw ADC values to physical units"""
        if not self.capabilities:
            raise RuntimeError("Device not connected")
        
        # Voltage conversion (ADC counts to Volts)
        voltage = (raw_data.voltage_raw * self.capabilities.voltage_resolution * 
                  self.voltage_calibration["scale"] + self.voltage_calibration["offset"])
        
        # Current conversion (ADC counts to Amperes)
        current = (raw_data.current_raw * self.capabilities.current_resolution * 
                  self.current_calibration["scale"] + self.current_calibration["offset"])
        
        result = {
            "timestamp": raw_data.timestamp,
            "channel": raw_data.channel,
            "voltage": voltage,  # V
            "current": current * 1e9,  # nA
        }
        
        # Temperature conversion (if available)
        if raw_data.temperature_raw is not None:
            # Assuming linear sensor: T(°C) = (ADC * 0.1) - 40
            result["temperature"] = (raw_data.temperature_raw * 0.1) - 40.0
        
        # Pressure conversion (if available)
        if raw_data.pressure_raw is not None:
            # Assuming linear sensor: P(kPa) = ADC * 0.01
            result["pressure"] = raw_data.pressure_raw * 0.01
        
        return result
    
    def get_buffer_data(self, num_points: Optional[int] = None) -> List[Dict[str, float]]:
        """Get converted data from buffer"""
        if num_points is None:
            raw_data = self.data_buffer
        else:
            raw_data = self.data_buffer[-num_points:]
        
        return [self.convert_raw_to_physical(data) for data in raw_data]
    
    def clear_buffer(self):
        """Clear data buffer"""
        self.data_buffer.clear()
